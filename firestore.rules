rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles — only the owner or admin can read/write
    match /profiles/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || request.auth.token.is_admin == true);
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (request.auth.uid == userId || request.auth.token.is_admin == true);
      allow delete: if request.auth != null && request.auth.token.is_admin == true;
    }

    // User data — only the owner or admin can read/write
    match /userdata/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || request.auth.token.is_admin == true);
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
