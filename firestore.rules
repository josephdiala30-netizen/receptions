rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles — only the owner or admin can read/write
    match /profiles/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || request.auth.token.is_admin == true);
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (request.auth.uid == userId || request.auth.token.is_admin == true);
      allow delete: if request.auth != null && request.auth.token.is_admin == true;
    }

    // User data — only the owner or admin can read/write
    match /userdata/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || request.auth.token.is_admin == true);
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Shared tasks — any authenticated user can assign tasks to others.
    // Only the assigner or assignee can read/update; only assigner or admin can delete.
    match /shared_tasks/{docId} {
      allow read: if request.auth != null && (
        resource.data.assignedToUid == request.auth.uid ||
        resource.data.assignedByUid == request.auth.uid ||
        request.auth.token.is_admin == true
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.assignedToUid == request.auth.uid ||
        resource.data.assignedByUid == request.auth.uid
      );
      allow delete: if request.auth != null && (
        resource.data.assignedByUid == request.auth.uid ||
        request.auth.token.is_admin == true
      );
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
